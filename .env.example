# Copy this file to `.env` and fill in the values. `.env` is gitignored.
# Every value is optional – sensible Nearmark defaults apply when a value is blank
# (see src/config.js). Only the Supabase pair is needed for a real backend; with
# it blank the app runs on the bundled seed data.

# ── Identity ──────────────────────────────────────────────────────────────────
VITE_APP_NAME="Nearmark"                 # product name (browser tab + installed app)
VITE_APP_SHORT_NAME="Nearmark"           # home-screen / app icon label
VITE_ORG_NAME="Nearmark"                 # wordmark shown in-app (top-left)
VITE_BRAND_BARS=""                       # logo-mark bar colours, comma-separated hex (blank = neutral default)
VITE_LOGO_URL=""                         # optional in-app logo image URL (blank = wordmark + bar mark, never another org's logo)
VITE_ICON_URL=""                         # optional install/home-screen icon (square ~512px PNG URL) → PWA manifest + favicon + apple-touch; blank = neutral placeholder
VITE_APP_DESCRIPTION="A walking guide to the history hidden in your city’s streets."
VITE_THEME_COLOR="#17111f"               # browser UI / PWA splash colour
VITE_THEME="default"                     # named palette in src/themes (e.g. "tollesbury"); blank = default dark
VITE_PUBLIC_URL=""                       # canonical URL for "Share this app" (blank = current site origin)

# ── Copy ({city} is replaced with the active city name; use \n for a line break) ──
VITE_COVER_HEADLINE="Hidden {city}"      # big cover headline (e.g. "Hidden\n{city}")
VITE_COVER_INTRO="Centuries of hidden history, in the streets of {city}."
VITE_SPLASH_TITLE="History, where it actually happened"
VITE_SPLASH_BODY="We use your location only to surface history near you. Nothing is stored or shared – it never leaves your device."
VITE_DISCOVERY_PROMPT="Discovery Mode alerts you when you’re near a site. Enable location to unlock stories as you walk – it never leaves your device."
VITE_DISCOVERY_SCAN_LABEL="Scan for nearby stories"
VITE_COMPLETION_MESSAGE="You’ve walked the route. The stories don’t end here – keep exploring in Discovery Mode any time."
VITE_STORY_LINK_LABEL="Read the full article"  # label for a location's external link (e.g. "Visit the artist’s website")

# ── Content source / attribution (blank hides the credit lines) ───────────────
VITE_CONTENT_SOURCE_LABEL=""             # e.g. "example.org" → shows "Content from example.org"
VITE_PLATFORM_NAME="Nearmark"            # "Powered by …" footer attribution
VITE_PLATFORM_URL=""                     # link for the platform name (blank = plain text)
VITE_CONTENT_SOURCE_NOTE=""              # sourcing paragraph shown in Settings
VITE_WIKI_BASE_URL=""                    # e.g. "https://example.org/wiki/" – article-link base + admin URL validation
VITE_REPO_URL=""                         # source-code link shown in admin → User management

# ── Supabase (backend: database + auth + storage) ─────────────────────────────
# The publishable (anon) key is safe in the client – Row Level Security protects
# the data (anon sees only published rows). Admin login is real email/password.
# Find both in Supabase → Project Settings → API. Leave blank to use seed data.
VITE_SUPABASE_URL=https://YOURPROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_XXXXXXXXXXXXXXXX

# ── PostHog product analytics (optional) ──────────────────────────────────────
# Project token is a public, write-only client key (safe in the bundle). Leave
# blank to disable analytics. Honours the browser "Do Not Track" signal.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# ── Active city + map defaults ────────────────────────────────────────────────
VITE_CITY_NAME=""                        # active city label (e.g. "Tollesbury"); blank = bundled seed city
VITE_CITY_AREA=""                        # city sub-label (e.g. "Essex")
VITE_CITIES=""                           # admin city options, comma-separated (e.g. "London,Brighton"); blank = just VITE_CITY_NAME
VITE_MAP_CENTER_LAT=51.5072
VITE_MAP_CENTER_LNG=-0.1276
VITE_MAP_ZOOM=15
