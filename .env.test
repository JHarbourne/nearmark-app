# Test build: blank Supabase → the app serves the bundled seed data, so the
# accessibility tests scan deterministic content locally and in CI (no secrets).
# Theme pinned to the default so a local build (which may set a client theme in
# .env) matches CI; the live per-client themes are covered by the scheduled scan.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_THEME=
VITE_APP_NAME=Nearmark
