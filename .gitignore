# Dependencies
node_modules/

# Environment / secrets (never commit real tokens)
.env
.env.local
*.env
.env.*          # .env.staging, .env.clean, etc. (Vercel pulls hold live tokens)
!.env.example   # keep the checked-in template
!.env.test      # keep the checked-in test config

# Build output
dist/

# Playwright (a11y tests)
test-results/
playwright-report/
blob-report/
playwright/.cache/

# macOS
.DS_Store

# Supabase CLI local scratch state (never commit)
supabase/.temp/
supabase/.branches/
